<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>{{ subject }}</title>
    <style>
      body {
        margin: 0; padding: 12px 20px;
        background-color: #ffffff;
        font-family: -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
        color: #111;
        font-size: 13px;
        line-height: 1.4;
      }

      /* ── 상단 메타 ── */
      .top-meta {
        font-size: 11px;
        color: #888;
        margin-bottom: 12px;
        border-bottom: 2px solid #111;
        padding-bottom: 6px;
      }

      /* ── 섹션 ── */
      .section { margin-bottom: 20px; }

      .sec-header {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 6px;
        padding-bottom: 3px;
        border-bottom: 1px solid #ddd;
      }
      .sec-header-high   { color: #c00; border-color: #c00; }
      .sec-header-medium { color: #b45309; border-color: #b45309; }
      .sec-header-low    { color: #888; border-color: #ccc; }

      /* ── 아이템 ── */
      .item {
        padding: 6px 0;
        border-bottom: 1px solid #f0f0f0;
      }
      .item:last-child { border-bottom: none; }

      /* ── 메타 줄 ── */
      .item-meta { margin-bottom: 2px; line-height: 1.6; }
      .tag {
        display: inline-block;
        padding: 0 6px;
        border-radius: 2px;
        font-size: 11px;
        font-weight: 600;
        margin-right: 4px;
        vertical-align: middle;
      }
      .tag-source  { background-color: #e8f0fe; color: #1a56db; }
      .tag-kind    { background-color: #f3f0ff; color: #6c3fc7; }
      .tag-new     { background-color: #e6f4ea; color: #1b6b3a; }
      .tag-updated { background-color: #fef3e2; color: #92400e; }
      .item-date   { font-size: 11px; color: #aaa; vertical-align: middle; }

      /* ── 제목 ── */
      .item-title {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #111;
        text-decoration: none;
        margin: 1px 0 4px;
        line-height: 1.4;
      }
      .item-title:hover { text-decoration: underline; }

      /* ── 요약 ── */
      .item-summary {
        font-size: 12px;
        color: #444;
        line-height: 1.6;
        margin-bottom: 3px;
        padding-left: 8px;
        border-left: 2px solid #ccc;
      }

      /* ── 이유 (summary 없을 때) ── */
      .item-reason {
        font-size: 11px;
        color: #777;
        line-height: 1.45;
      }

      /* ── 첨부 ── */
      .item-attach {
        font-size: 11px;
        color: #aaa;
        margin-top: 2px;
      }
      .item-attach a { color: #1a56db; text-decoration: none; }

      /* ── 자식 아이템 ── */
      .child-list {
        list-style: none;
        margin: 6px 0 0;
        padding: 0 0 0 16px;
        border-left: 2px solid #e0e0e0;
      }
      .child-item { padding: 6px 0; border-bottom: 1px solid #f5f5f5; }
      .child-item:last-child { border-bottom: none; }

      /* ── 오류 ── */
      .error-note {
        font-size: 12px;
        color: #c00;
        margin-bottom: 14px;
      }

      /* ── 푸터 ── */
      .footer { font-size: 11px; color: #bbb; margin-top: 24px; border-top: 1px solid #eee; padding-top: 8px; }
    </style>
  </head>
  <body>

    <div class="top-meta">
      {{ run_date[:10] }} &nbsp;·&nbsp; Legal &amp; Compliance Signal &nbsp;·&nbsp; 신규/변경 항목만 포함
    </div>

    {% if errors and errors|length > 0 %}
      <div class="error-note">⚠ 수집 오류 {{ errors|length }}건 — 일부 소스가 누락되었을 수 있습니다.</div>
    {% endif %}

    {% for sec in sections %}
      {% if sec.items|length > 0 %}
        {% set sec_key = sec.label | lower %}
        <div class="section">

          <div class="sec-header sec-header-{{ sec_key }}">
            {%- if sec_key == 'high' -%}▲ HIGH
            {%- elif sec_key == 'medium' -%}◆ MEDIUM
            {%- else -%}● LOW
            {%- endif -%}
            &nbsp;<span style="font-weight:400; font-size:11px;">({{ sec.items|length }}건)</span>
          </div>

          {% for it in sec.items %}
            <div class="item">

              <div class="item-meta">
                <span class="tag tag-source">{{ it.source_name_ko }}</span>
                <span class="tag tag-kind">{{ it.category_label }}</span>
                {% if not it.is_updated %}
                  <span class="tag tag-new">신규</span>
                {% endif %}
                {% if it.published_at and not it.summary %}
                  <span class="item-date">{{ it.published_at }}</span>
                {% endif %}
              </div>

              <a class="item-title" href="{{ it.url }}">{{ it.title }}</a>

              {% if it.summary %}
                <div class="item-summary">{{ it.summary }}</div>
              {% elif it.reason %}
                <div class="item-reason">{{ it.reason }}</div>
              {% endif %}

              {% if it.attachments|length > 0 %}
                <div class="item-attach">
                  첨부:
                  {% for a in it.attachments %}
                    <a href="{{ a.url }}">{{ a.label }}</a>{% if not loop.last %}, {% endif %}
                  {% endfor %}
                </div>
              {% endif %}

              {% if it.child_items|length > 0 %}
                <ul class="child-list">
                  {% for child in it.child_items %}
                    <li class="child-item">
                      <div class="item-meta">
                        <span class="tag tag-source">{{ child.source_name_ko }}</span>
                        <span class="tag tag-kind">{{ child.category_label }}</span>
                      </div>
                      <a class="item-title" href="{{ child.url }}" style="font-size:13px;">{{ child.title }}</a>
                      {% if child.reason %}<div class="item-reason">{{ child.reason }}</div>{% endif %}
                      {% if child.attachments|length > 0 %}
                        <div class="item-attach">
                          첨부:
                          {% for a in child.attachments %}
                            <a href="{{ a.url }}">{{ a.label }}</a>{% if not loop.last %}, {% endif %}
                          {% endfor %}
                        </div>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}

            </div>
          {% endfor %}

        </div>
      {% endif %}
    {% endfor %}

    <div class="footer">미래에셋생명보험 법무·컴플라이언스팀 내부 브리핑</div>

  </body>
</html>
